# Dependencies and build artifacts (rebuilt in Docker)
venv/
.venv/
frontend/node_modules/
frontend/dist/
backend/app/static/

# Secrets and env (mount at runtime; never bake into image)
.env
.env.*
!.env.example

# Runtime and persisted data (bind mounts at runtime)
backend/memory/
backend/logs/
backend/app/data/
backend/runtime/

# Git and IDE
.git/
.gitignore
.pytest_cache/
*.pyc
__pycache__/
*.pyo

# Docs and plans (not required for app to run)
.cursor/
*.plan.md

# Optional: keep image smaller
*.md
!backend/**/*.md
docs/
