# Syx AGI Chatbot Framework - Environment Variables
# Edit values as needed. Comments are placed after each variable to avoid parser conflicts.

# === Core: OpenAI + Chat Model ===
#OPENAI_API_KEY=your-openai-api-key-here
# OpenAI API key used for chat and embeddings

LLM_PROVIDER=openai
# LLM provider selector

MODEL_NAME=gpt-5.5
# Main runtime chat model selected by llm factory

LLM_MINI_MODEL=gpt-5-mini
# Mini runtime model selected by llm factory

MODEL_TEMPERATURE=1.0
# Sampling temperature (0.0–2.0)

MODEL_MAX_TOKENS=128000
# Max tokens in a single model response

AVAILABLE_MODELS=["gpt-5.5","gpt-5-mini","gpt-5.2","gpt-5.1","gpt-5.1-mini","gpt-5.1-nano","gpt-5","gpt-5-nano","gpt-4o","gpt-4o-mini","gpt-4.1","gpt-4.1-mini","gpt-4.1-nano"]
# Whitelisted chat models for the UI selector

# === Server + CORS ===
HOST=0.0.0.0
# Server host interface

PORT=8000
# Server port

RELOAD=true
# Enable auto-reload in development

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Allowed browser origins for API

# === Logging ===
LOG_LEVEL=INFO
# Log level (DEBUG, INFO, WARNING, ERROR)

LOG_LEVEL_CONSOLE=INFO
# Console log level (DEBUG, INFO, WARNING, ERROR)

LOG_LEVEL_FILE=DEBUG
# File log level (DEBUG, INFO, WARNING, ERROR)

LOG_MAX_BYTES=10485760
# Max bytes per rotating log file

LOG_BACKUP_COUNT=5
# Number of rotated log files per session

LOG_PREVIEW_MAX_CHARS=1024
# Max chars for log previews

# === Database + Storage ===
DB_PATH=../data/db/syx.db
# SQLite database file path (or full URL like sqlite:///...)

MEMORY_ROOT=../data/memory
RUNS_DIR=../runtime/runs
LOGS_DIR=../runtime/logs
LOG_FILE_PREFIX=syx_
LOCK_DIR=../runtime/state
# Runtime and storage roots
# (the test suite overrides LOGS_DIR to ../runtime/logs/tests and LOG_FILE_PREFIX to test_)

MAX_UPLOAD_MB=10
# Max size per uploaded file (MB)

MAX_BATCH_MB=50
# Max total size per upload request (MB)

STORAGE_LIMIT_MB=500
# Per-project storage cap (MB)

# === Embeddings + Indexing ===
EMBEDDING_PROVIDER=sentence_transformers
# Embedding provider selector (openai|sentence_transformers)

EMBEDDING_MODEL=text-embedding-3-large
# OpenAI embedding model for document indexing

SENTENCE_TRANSFORMERS_MODEL_ID=BAAI/bge-m3
# Local sentence-transformers model id (used when EMBEDDING_PROVIDER=sentence_transformers)

CHUNK_SIZE=600
# Text chunk size used during embedding

CHUNK_OVERLAP=80
# Overlap between chunks during embedding

MAX_EMBED_TOKENS_PER_REQUEST=180000
# Safety cap: max total tokens per embeddings API request (headroom under provider cap)

RAG_EMBED_REBUILD_WORKERS=3
# Parallel workers for LTM embedding during rebuild (range 1-8)

# === RAG (Main / LTM) ===
RAG_ON_CHAT=true
# If true, inject retrieved context into chat when index exists

BASE_TOP_K=6
# Base top-K used to derive per-source retrieval K

RETRIEVAL_MULTIPLIER=2.0
# PER_SOURCE_K = ceil(BASE_TOP_K * RETRIEVAL_MULTIPLIER)

RAG_SCORE_THRESHOLD=0.50
# Cosine similarity threshold (0..1) to include snippet

AGENT_MEMORY_MAX_ENTRY_CHARS=25000
# Max serialized agent memory snippet size for full-entry expansion

# === Daily Memory + Daily RAG ===
CHAT_HISTORY_LIMIT_PAIRS=3
# Number of prompt/response pairs kept in working memory

DAILY_RAG_SCORE_THRESHOLD=0.40
# Similarity threshold for daily results

# === Query Builder + Reranking ===
BUILDER_MODEL=gpt-5-mini
# LLM for query builder/router

TAGGER_MODEL=gpt-5-mini
# LLM used for tagging

BUILDER_MAX_TOKENS=1024
# Max tokens for builder output

BUILDER_CACHE=true
# Enable in-memory builder cache

# === Working Memory ===
CHAT_HISTORY_LIMIT=20
# Number of recent messages kept per project in working memory

# === Project Defaults (seeded files) ===
DEFAULT_SYSTEM_PROMPT_PATH=backend/app/config/defaults/system_prompt.txt
# Default system prompt file path

DEFAULT_PERSONALITY_PROMPT_PATH=backend/app/config/defaults/personality.json
# Default personality JSON file path

# === Sleep Cycle + Verification ===
ENABLE_SCHEDULER=true
# Enable daily sleep scheduler

SLEEP_CYCLE_HOUR=3
# Local hour of day (0-23) to run sleep cycle

SLEEP_CYCLE_MINUTE=0
# Local minute of day (0-59) to run sleep cycle

VERIFY_RAG=true
# Enable post-rebuild verification

FORCE_RAG_REBUILD_ON_STARTUP=false
# Optional startup sweep: rebuild all project RAG indexes from uploads

# === Instrumentation (V5.0) ===
INSTRUMENTATION_ENABLED=false
# Enable run/turn/invocation telemetry collection

INSTRUMENTATION_MODE=metrics
# metrics|research (research permits artifact capture)

# INSTRUMENTATION_RUN_ID=<optional-run-id>
# Optional run id override; leave commented to use runtime-generated ids

INSTRUMENTATION_RUNS_DIR=../runtime/runs
# Root folder for instrumentation outputs

INSTRUMENTATION_PROMPT_TOL_ABS_TOKENS=25
# Absolute prompt token tolerance for accounting validation

INSTRUMENTATION_PROMPT_TOL_PCT=0.02
# Relative prompt token tolerance (fraction)

# === Streaming Chat ===
STREAMING_ENABLED=true
# Enable streaming chat endpoint

TAGGER_CURRENT_RESPONSE_MIDDLE_CUT_PERCENT=50
# Tagger prompt optimization: percent removed from center of current assistant text (range: 10-90, int)

TAGGER_PREVIOUS_RESPONSE_MIDDLE_CUT_PERCENT=75
# Tagger prompt optimization: percent removed from center of previous assistant text (range: 10-90, int)

TAGGER_MIN_RESPONSE_LENGTH_FOR_CHOP=600
# Tagger prompt optimization: apply chopping only when assistant text length is greater than this value

# === Response Pruning ===
RESPONSE_PRUNING_RULES_PATH=backend/app/config/rules.json
# JSON rule file for deterministic response pruning

RESPONSE_PRUNING_MAX_FRONT_UNITS=3
# Max leading sentence units removed by response pruning

RESPONSE_PRUNING_SIMILARITY_THRESHOLD=90
# Similarity threshold for duplicate-sentence response pruning (0-100)

RESPONSE_PRUNING_WHITESPACE_MODE=compact_prose
# Response-pruning whitespace mode: off|compact_prose|preserve_code

RESPONSE_PRUNING_ENABLED=true
# Enable deterministic response pruning

RESPONSE_PRUNING_FRONT_ENABLED=true
# Enable response-pruning front sentence trimming

RESPONSE_PRUNING_END_ENABLED=true
# Enable response-pruning trailing paragraph trimming

RESPONSE_PRUNING_MARKDOWN_ENABLED=false
# Enable response-pruning markdown cleanup

RESPONSE_PRUNING_WHITESPACE_ENABLED=true
# Enable response-pruning whitespace cleanup

RESPONSE_PRUNING_SIMILARITY_ENABLED=true
# Enable response-pruning duplicate-sentence similarity scan

# === Dream Pipeline ===
ENABLE_DREAM=true
# Enable Dream orchestrator

AUTO_ACCEPT_DREAMS=true
# Automatically persist all pending dream.json items during sleep

DREAM_MODEL=gpt-5.5
DREAM_TEMPERATURE=1.0
DREAM_MAX_TOKENS=32000
DREAM_ENABLE_REMOTE_RESEARCH=true
DREAM_REMOTE_CONTEXT_MAX_TOKENS=32000
# Dream agent configuration

# === Debug / Observability ===
GENERATE_DEBUG_FILES=true
# Enable debug file generation (e.g., debug_context.txt)

VITE_SHOW_DEBUG_VALUES=false
# Frontend: show stats/debug values bar in chat UI

