# Morpheus AGI Chatbot Framework - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI Configuration (Required)
OPENAI_API_KEY=your-openai-api-key-here

# Model Configuration (Optional)
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=1000

# Server Configuration (Optional)
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Logging Configuration (Optional)
LOG_LEVEL=INFO
LOG_FORMAT=json

# Future Features (Placeholders for V2-V4)
# RAG Configuration (V2)
# RAG_INDEX_PATH=./data/rag_index
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200

# Memory Configuration (V3)
# MEMORY_RETENTION_DAYS=30
# MEMORY_CLEANUP_HOUR=2

# Project Configuration (V4)
# DEFAULT_PROJECT_ID=default
# MAX_PROJECTS=10
