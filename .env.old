# Morpheus AGI Chatbot Framework - Environment Variables
# Edit values as needed. Comments are placed after each variable to avoid parser conflicts.

OPENAI_API_KEY=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
# OpenAI API key used for chat and embeddings

MODEL_NAME=gpt-5
# Default chat model name

MODEL_TEMPERATURE=1.0
# Sampling temperature (0.0–2.0)

MODEL_MAX_TOKENS=32000
# Max tokens in a single model response

HOST=0.0.0.0
# Server host interface

PORT=8000
# Server port

RELOAD=true
# Enable auto-reload in development

LOG_LEVEL=INFO
# Log level (DEBUG, INFO, WARNING, ERROR)

LOG_FORMAT=json
# Log format: json or text

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Allowed browser origins for API

DB_PATH=backend/app/data/morpheus.db
# SQLite database file path (or full URL like sqlite:///...)

MAX_UPLOAD_MB=10
# Max size per uploaded file (MB)

MAX_BATCH_MB=50
# Max total size per upload request (MB)

STORAGE_LIMIT_MB=500
# Per-project storage cap (MB)

EMBEDDING_MODEL=text-embedding-3-large
# Embedding model for document indexing

CHUNK_SIZE=800
# Text chunk size used during embedding

CHUNK_OVERLAP=100
# Overlap between chunks during embedding

AVAILABLE_MODELS=["gpt-5","gpt-5-mini","gpt-5-nano","gpt-4o","gpt-4o-mini","gpt-4.1","gpt-4.1-mini","gpt-4.1-nano"]
# Whitelisted chat models for the UI selector

RAG_ON_CHAT=true
# If true, inject retrieved context into chat when index exists

RAG_TOP_K=10
# Number of top snippets to retrieve

RAG_SNIPPET_MAX_TOKENS=500
# Max tokens per RAG snippet

RAG_CONTEXT_MAX_TOKENS=5000
# Max total tokens for injected context block

RAG_SCORE_THRESHOLD=0.5
# Cosine similarity threshold (0..1) to include snippet

CHAT_HISTORY_LIMIT=20
# Number of recent messages kept per project in working memory
